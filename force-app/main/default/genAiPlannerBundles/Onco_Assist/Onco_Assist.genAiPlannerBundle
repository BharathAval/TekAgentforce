            <language>en_US</language>
            <masterLabel>instructions_0_1775715023516</masterLabel>
            <sortOrder>2</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
            <description>Never provide generic information, advice or troubleshooting steps, unless retrieved from searching knowledge articles.</description>
            <developerName>instructions_0_1775718103650</developerName>
            <language>en_US</language>
            <masterLabel>instructions_0_1775718103650</masterLabel>
            <sortOrder>3</sortOrder>
        </genAiPluginInstructions>
        <genAiPluginInstructions>
